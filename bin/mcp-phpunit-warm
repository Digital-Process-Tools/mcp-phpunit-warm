#!/usr/bin/env php
<?php

declare(strict_types=1);

@ini_set('memory_limit', '-1');
// Dual-mode autoload: local clone vs. composer-global install.
foreach ([
    __DIR__ . '/../vendor/autoload.php',       // local dev: composer install in this repo
    __DIR__ . '/../../../autoload.php',         // composer global / project-local require
] as $autoload) {
    if (is_file($autoload)) {
        require $autoload;
        break;
    }
}

use Mcp\Server;
use Mcp\Server\Transport\StdioTransport;

// Parse our own CLI flags BEFORE loading phpunit — keeps Server lean.
$workingDir = null;
$config = null;
foreach (array_slice($argv, 1) as $arg) {
    if (str_starts_with($arg, '--working-dir=')) {
        $workingDir = substr($arg, 14);
    } elseif (str_starts_with($arg, '--config=')) {
        $config = substr($arg, 9);
    }
}

if ($workingDir !== null) {
    if (!is_dir($workingDir)) {
        fwrite(STDERR, "mcp-phpunit-warm: --working-dir not a directory: {$workingDir}\n");
        exit(2);
    }
    chdir($workingDir);
}

// Hand the --config flag to PhpunitRunner via env var so we don't clobber $_SERVER['argv']
// before the MCP SDK has a chance to use it.
if ($config !== null) {
    putenv('MCP_PHPUNIT_CONFIG=' . $config);
}

$server = Server::builder()
    ->setServerInfo('mcp-phpunit-warm', '0.1.0')
    ->setDiscovery(dirname(__DIR__), ['src'])
    ->build();

$server->run(new StdioTransport());
