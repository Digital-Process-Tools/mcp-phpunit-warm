#!/usr/bin/env php
<?php

declare(strict_types=1);

@ini_set('memory_limit', '-1');
// Dual-mode autoload: local clone vs. composer-global install.
foreach ([
    __DIR__ . '/../vendor/autoload.php',       // local dev: composer install in this repo
    __DIR__ . '/../../../autoload.php',         // composer global / project-local require
] as $autoload) {
    if (is_file($autoload)) {
        require $autoload;
        break;
    }
}

use Dpt\McpPhpunitWarm\PhpunitRunner;
use Mcp\Server;
use Mcp\Server\Transport\StdioTransport;

// Parse our own CLI flags BEFORE loading phpunit — keeps Server lean.
$workingDir = null;
$config     = null;
// Prewarm is opt-in: PHPUnit's --list-tests writes via php://stdout (bypasses ob_start)
// which corrupts MCP stdio transport on projects with large test suites. Enable with --prewarm
// only when you've verified your test framework doesn't dump to stdout during list-tests.
$prewarm    = false;

foreach (array_slice($argv, 1) as $arg) {
    if (str_starts_with($arg, '--working-dir=')) {
        $workingDir = substr($arg, 14);
    } elseif (str_starts_with($arg, '--config=')) {
        $config = substr($arg, 9);
    } elseif ($arg === '--prewarm') {
        $prewarm = true;
    } elseif ($arg === '--no-prewarm') {
        $prewarm = false;
    }
}

if ($workingDir !== null) {
    if (!is_dir($workingDir)) {
        fwrite(STDERR, "mcp-phpunit-warm: --working-dir not a directory: {$workingDir}\n");
        exit(2);
    }
    chdir($workingDir);
}

// Hand the --config flag to PhpunitRunner via env var so we don't clobber $_SERVER['argv']
// before the MCP SDK has a chance to use it.
if ($config !== null) {
    putenv('MCP_PHPUNIT_CONFIG=' . $config);
}

// Pre-warm: run --list-tests once at daemon startup to trigger phpunit.xml bootstrap
// and autoload. Individual test calls then skip the framework boot cost (~800ms saved).
$runner = new PhpunitRunner();

if ($prewarm) {
    $prewarmArgv = ['phpunit'];
    if ($config !== null) {
        $prewarmArgv[] = '--configuration';
        $prewarmArgv[] = $config;
    }
    $runner->prewarm($prewarmArgv);
}

PhpunitRunner::setShared($runner);

$server = Server::builder()
    ->setServerInfo('mcp-phpunit-warm', '0.2.0')
    ->setDiscovery(dirname(__DIR__), ['src'])
    ->build();

$server->run(new StdioTransport());
